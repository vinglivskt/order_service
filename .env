APP_NAME=order-service
DEBUG=false

SECRET_KEY=super-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

REDIS_URL=redis://redis:6379/0
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/orders_db

KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_NEW_ORDER=new-order
KAFKA_TOPIC_ORDER_EVENTS=order-events
KAFKA_TOPIC_ORDER_EVENTS_DLQ=order-events-dlq
OUTBOX_MAX_ATTEMPTS=3

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
RATE_LIMIT_DEFAULT=100/minute
ORDERS_CACHE_TTL_SECONDS=300
AUTH_USER_CACHE_TTL_SECONDS=60
